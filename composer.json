{
    "name": "mongodb/mongodb-driver-revoltphp",
    "description": "Pure userland async PHP 8.4+ MongoDB driver using RevoltPHP",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-gmp": "*",
        "ext-mbstring": "*",
        "revolt/event-loop": "^1.0",
        "amphp/socket": "^2.0",
        "amphp/amp": "^3.0"
    },
    "require-dev": {
        "doctrine/coding-standard": "^12.0",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "files": [
            "src/BSON/functions.php",
            "src/Driver/Monitoring/functions.php"
        ],
        "psr-4": {
            "MongoDB\\BSON\\": "src/BSON/",
            "MongoDB\\Driver\\": "src/Driver/",
            "MongoDB\\Internal\\": "src/Internal/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MongoDB\\Tests\\": "tests/"
        }
    },
    "provide": {
        "ext-mongodb": "*"
    },
    "conflict": {
        "ext-mongodb": "*"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
