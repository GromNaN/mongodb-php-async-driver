{
    "name": "mongodb/driver-benchmark",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "../",
            "symlink": true
        }
    ],
    "replace": {
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "require": {
        "php": ">=8.4",
        "ext-pcntl": "*",
        "amphp/parallel": "^2.2",
        "mongodb/async-driver": "@dev",
        "phpbench/phpbench": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "MongoDB\\Benchmark\\": "src/"
        }
    },
    "scripts": {
        "benchmark": "phpbench run --report=aggregate"
    },
    "config": {
        "sort-packages": true
    }
}
